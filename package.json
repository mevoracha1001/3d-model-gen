{
  "name": "spec2mesh",
  "version": "0.1.0",
  "description": "Open-source AI studio for turning specs, photos, and dimensions into printable 3D models.",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build && node scripts/validate-artifact.mjs",
