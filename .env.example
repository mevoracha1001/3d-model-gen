# URL of the AI bridge server (see bridge/server.mjs)
CODEX_BRIDGE_URL=http://127.0.0.1:8788

# Dev-only auth bypass — set these to skip ChatGPT auth in local development
DEV_AUTH_EMAIL=local@dev.local
DEV_AUTH_NAME=Local Dev User

# Optional: override which Cloudflare bindings to use (for local dev with wrangler)
# CF_D1_BINDING=DB
# CF_R2_BINDING=IMAGES
